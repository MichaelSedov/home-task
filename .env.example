# Copy to .env and fill in values for local development.

# Required: HMAC key for signed session cookies. Any 32+ character random string.
SESSION_SECRET=change-me-to-a-random-32-char-string

# Production-only: absolute origin baked into canonical / hreflang / sitemap
# URLs at build time. Set in Vercel project settings, e.g.:
#   PUBLIC_ORIGIN=https://home-task-red.vercel.app
# Local dev falls back to the request's url.origin so this can stay unset.
# PUBLIC_ORIGIN=
