{
	"name": "app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest --run",
		"test:e2e": "playwright test",
		"test": "npm run test:unit && npm run test:e2e",
		"lhci": "lhci autorun",
		"size": "size-limit"
	},
	"lint-staged": {
		"*.{ts,js,svelte}": [
			"prettier --write",
			"eslint --fix"
		],
		"*.{css,json,md}": [
			"prettier --write"
		]
	},
	"size-limit": [
		{
			"name": "Public entry chunk",
			"path": ".svelte-kit/output/client/_app/immutable/entry/*.js",
			"limit": "100 KB",
			"gzip": true
		},
		{
			"name": "Public app shell (entry + shared chunks)",
			"path": [
				".svelte-kit/output/client/_app/immutable/entry/*.js",
				".svelte-kit/output/client/_app/immutable/chunks/*.js"
			],
			"limit": "320 KB",
			"gzip": true
		}
	],
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@eslint/js": "^10.0.1",
		"@lhci/cli": "^0.15.1",
		"@playwright/test": "^1.60.0",
		"@size-limit/file": "^12.1.0",
		"@size-limit/preset-small-lib": "^12.1.0",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^20",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.7",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"size-limit": "^12.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"web-vitals": "^5.3.0",
		"zod": "^4.4.3"
	}
}
